# ==========================================
# BACKEND CONFIGURATION (Railway)
# ==========================================

# Neon PostgreSQL Database Connection String
# Example: postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require
DATABASE_URL=

# JWT Secret for authentication tokens
# Generate a strong random string for production
JWT_SECRET=

# Frontend URL for CORS configuration (Vercel deployment)
# Example: https://orion-live.vercel.app
FRONTEND_URL=

# Server Port (Railway will set this automatically)
PORT=3000

# Node Environment
NODE_ENV=production

# ==========================================
# FRONTEND CONFIGURATION (Vercel)
# ==========================================

# Backend API URL for frontend fetch calls
# Example: https://orion-live-backend.railway.app
VITE_API_URL=

# Application URL
# Example: https://orion-live.vercel.app
VITE_APP_URL=
