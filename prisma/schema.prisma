// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. User (Vendeurs & Admins)
// ==========================================
enum UserRole {
  ADMIN
  SELLER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique @db.VarChar(255)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  name         String        @db.VarChar(100)
  role         UserRole      @default(SELLER)
  status       UserStatus    @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  
  lives        LiveSession[]
  products     Product[]
  auditLogs    AuditLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ==========================================
// 2. LiveSession Model (Boutique Éphémère)
// ==========================================
enum LiveStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  INACTIVE
  ENDED
  SOLD_OUT
  ARCHIVED
}

model LiveSession {
  id          String        @id @default(uuid()) @db.Uuid
  title       String        @db.VarChar(150)
  description String?       @db.Text
  imageUrl    String?       @map("image_url") @db.Text
  status      LiveStatus    @default(DRAFT)
  slug        String        @unique @db.VarChar(100)
  startDate   DateTime?     @map("start_date") @db.Timestamptz
  endDate     DateTime?     @map("end_date") @db.Timestamptz
  userId      String        @map("user_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  seller      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  products    LiveProduct[]
  visitors    Visitor[]
  savedProducts SavedProduct[]
  reservations Reservation[]
  auditLogs   AuditLog[]
  notifications LiveNotification[]
  contactRequests ContactRequest[]

  @@index([slug])
  @@index([userId, status])
  @@map("live_sessions")
}

// ==========================================
// 3. Product Model (Catalogue)
// ==========================================
model Product {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @db.VarChar(150)
  description String?       @db.Text
  price       Decimal       @db.Decimal(10, 2)
  stock       Int           @default(0)
  imageUrl    String?       @map("image_url") @db.Text
  isActive    Boolean       @default(true) @map("is_active")
  userId      String        @map("user_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  seller      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lives       LiveProduct[]
  savedProducts SavedProduct[]
  reservations Reservation[]

  @@index([userId])
  @@map("products")
}

// ==========================================
// 4. LiveProduct (Many-to-Many Join Table)
// ==========================================
model LiveProduct {
  liveSessionId String      @map("live_session_id") @db.Uuid
  productId     String      @map("product_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([liveSessionId, productId])
  @@index([productId])
  @@map("live_products")
}

// ==========================================
// 5. Visitor Model (Audience & Hot Prospects)
// ==========================================
model Visitor {
  id            String          @id @default(uuid()) @db.Uuid
  pseudo        String          @db.VarChar(50)
  whatsapp      String?         @db.VarChar(30)
  score         Int             @default(1)
  liveSessionId String          @map("live_session_id") @db.Uuid
  joinedAt      DateTime        @default(now()) @map("joined_at") @db.Timestamptz
  lastActiveAt  DateTime        @default(now()) @map("last_active_at") @db.Timestamptz

  liveSession   LiveSession     @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  actions       VisitorAction[]

  @@index([liveSessionId, pseudo])
  @@map("visitors")
}

// ==========================================
// 6. VisitorAction Model (Scoring Triggers)
// ==========================================
model VisitorAction {
  id            String      @id @default(uuid()) @db.Uuid
  visitorId     String      @map("visitor_id") @db.Uuid
  actionType    String      @map("action_type") @db.VarChar(50) // 'visit', 'view_product', 'save_product', 'reservation', 'contact_request'
  productId     String?     @map("product_id") @db.Uuid
  details       String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  visitor       Visitor     @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([visitorId])
  @@index([createdAt])
  @@map("visitor_actions")
}

// ==========================================
// 7. SavedProduct Model (❤️ Ajouter à la liste)
// ==========================================
model SavedProduct {
  id            String      @id @default(uuid()) @db.Uuid
  visitorPseudo String      @map("visitor_pseudo") @db.VarChar(50)
  productId     String      @map("product_id") @db.Uuid
  liveSessionId String      @map("live_session_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([liveSessionId, productId])
  @@map("saved_products")
}

// ==========================================
// 8. Reservation Model (🛒 Réservation)
// ==========================================
model Reservation {
  id            String      @id @default(uuid()) @db.Uuid
  visitorPseudo String      @map("visitor_pseudo") @db.VarChar(50)
  whatsapp      String?     @db.VarChar(30)
  productId     String      @map("product_id") @db.Uuid
  liveSessionId String      @map("live_session_id") @db.Uuid
  quantity      Int         @default(1)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([liveSessionId, productId])
  @@index([createdAt])
  @@map("reservations")
}

// ==========================================
// 9. ContactRequest Model (📞 Être contacté)
// ==========================================
model ContactRequest {
  id            String      @id @default(uuid()) @db.Uuid
  visitorPseudo String      @map("visitor_pseudo") @db.VarChar(50)
  whatsapp      String      @db.VarChar(30)
  liveSessionId String      @map("live_session_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)

  @@index([liveSessionId])
  @@index([createdAt])
  @@map("contact_requests")
}

// ==========================================
// System-Level and Multi-Tenant Support
// ==========================================

model AuditLog {
  id            String       @id @default(uuid()) @db.Uuid
  liveSessionId String?      @map("live_session_id") @db.Uuid
  visitorPseudo String?      @map("visitor_pseudo") @db.VarChar(50)
  userId        String?      @map("user_id") @db.Uuid
  actionType    String       @map("action_type") @db.VarChar(50) 
  productName   String?      @map("product_name") @db.VarChar(150)
  details       String?      @db.Text
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  liveSession   LiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([liveSessionId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model LiveNotification {
  id            String      @id @default(uuid()) @db.Uuid
  liveId        String      @map("live_id") @db.Uuid
  pseudo        String      @db.VarChar(50)
  whatsapp      String?     @db.VarChar(30)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  liveSession   LiveSession @relation(fields: [liveId], references: [id], onDelete: Cascade)

  @@index([liveId])
  @@map("live_notifications")
}

model AdminNotification {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(150)
  message   String   @db.Text
  type      String   @db.VarChar(50) 
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("admin_notifications")
}

model SystemAlert {
  id         String   @id @default(uuid()) @db.Uuid
  title      String   @db.VarChar(150)
  message    String   @db.Text
  severity   String   @db.VarChar(20) 
  isResolved Boolean  @default(false) @map("is_resolved")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("system_alerts")
}

model SystemConfig {
  key   String @id @db.VarChar(100)
  value String @db.Text

  @@map("system_config")
}
